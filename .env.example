# ── OrbisClin Cold — Configuração ─────────────────────────────────────────────
# Copie este arquivo para .env e ajuste antes de iniciar

APP_NAME="OrbisClin Cold"
APP_ENV=development
SECRET_KEY=TROQUE-POR-STRING-ALEATORIA-DE-64-CARACTERES-MINIMO
COOKIE_NAME=cold_session
COOKIE_SECURE=false

DATABASE_URL=sqlite:///./orbisclin_cold.db

REDIS_URL=redis://localhost:6379/1
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/1

SENSOR_POLL_INTERVAL_SECONDS=60
OFFLINE_THRESHOLD_MINUTES=5
ACCESS_TOKEN_EXPIRE_MINUTES=480

SMTP_HOST=smtp.hospital.com.br
SMTP_PORT=587
SMTP_USER=cold@hospital.com.br
SMTP_PASSWORD=
SMTP_FROM=cold@hospital.com.br
SMTP_TLS=true

PORT=8001
