# Ambiente
APP_ENV=development
PORT=8001

# Segurança (obrigatório, mínimo 32 caracteres)
SECRET_KEY=substitua-por-uma-chave-secreta-longa-e-aleatoria-aqui

# Banco de Dados
DATABASE_URL=sqlite:///./orbisclin.db

# Redis / Celery
REDIS_URL=redis://localhost:6379/0

# Sensores
SENSOR_POLL_INTERVAL_SECONDS=60
OFFLINE_THRESHOLD_MINUTES=5

# Email (opcional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_app
SMTP_FROM=seu_email@gmail.com
SMTP_TLS=true

# CORS
CORS_ORIGINS=["http://localhost:8001","http://127.0.0.1:8001"]

# Logging
LOG_LEVEL=INFO